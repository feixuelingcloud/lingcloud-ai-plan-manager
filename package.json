{
  "name": "lingcloud-ai-plan-manager",
  "version": "1.0.0",
  "description": "A powerful OpenClaw plugin for intelligent plan and task management with AI assistance",
  "type": "module",
  "main": "dist/index.js",
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx index.ts",
    "check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/lingcloud-ai-plan-manager.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/lingcloud-ai-plan-manager/issues"
  },
  "homepage": "https://github.com/YOUR_USERNAME/lingcloud-ai-plan-manager#readme",
  "dependencies": {
    "@sinclair/typebox": "^0.34.28"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "plan-manager",
    "task-management",
    "ai",
    "ai-assistant",
    "productivity",
    "project-management"
  ],
  "author": "Lingyun <your-email@example.com>",
  "license": "MIT"
}
